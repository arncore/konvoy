<idea-plugin>
    <id>com.konvoy.ide</id>
    <name>Konvoy</name>
    <vendor url="https://github.com/arncore/konvoy">Konvoy</vendor>
    <description><![CDATA[
        Kotlin/Native project support for <a href="https://github.com/arncore/konvoy">Konvoy</a> build tool.
        <br/>
        Provides project model integration, run configurations, and toolchain management
        for projects using <code>konvoy.toml</code>.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>
    <depends>org.toml.lang</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
        <projectConfigurator implementation="com.konvoy.ide.sync.KonvoyKotlinProjectConfigurator"/>
        <buildSystemTypeDetector implementation="com.konvoy.ide.sync.KonvoyBuildSystemTypeDetector"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <!-- SDK type for Konvoy toolchains -->
        <sdkType implementation="com.konvoy.ide.sdk.KonvoySdkType"/>

        <!-- Run configurations -->
        <configurationType implementation="com.konvoy.ide.run.KonvoyConfigurationType"/>
        <runConfigurationProducer
                implementation="com.konvoy.ide.run.KonvoyRunConfigurationProducer"
                order="first"/>

        <!-- Gutter run icons -->
        <runLineMarkerContributor
                language="kotlin"
                implementation="com.konvoy.ide.run.KonvoyRunLineMarkerContributor"/>
        <runLineMarkerContributor
                language="kotlin"
                implementation="com.konvoy.ide.run.KonvoyTestLineMarkerContributor"/>

        <!-- Clickable file:line:col links in build output -->
        <consoleFilterProvider
                implementation="com.konvoy.ide.run.KonvoyConsoleFilterProvider"/>

        <!-- Project services -->
        <projectService
                serviceImplementation="com.konvoy.ide.sync.KonvoyProjectService"/>
        <projectService
                serviceImplementation="com.konvoy.ide.build.KonvoyExternalAnnotatorService"/>
        <projectService
                serviceImplementation="com.konvoy.ide.build.KonvoyBuildSettings"/>
        <projectService
                serviceImplementation="com.konvoy.ide.build.KonvoyBuildStatusService"/>

        <!-- Build on save -->
        <statusBarWidgetFactory
                implementation="com.konvoy.ide.build.KonvoyBuildStatusWidgetFactory"
                id="KonvoyBuildStatus"/>
        <externalAnnotator
                language="kotlin"
                implementationClass="com.konvoy.ide.build.KonvoyExternalAnnotator"/>
        <projectConfigurable
                parentId="build"
                instance="com.konvoy.ide.build.KonvoyBuildConfigurable"
                displayName="Konvoy"
                id="konvoy.settings"/>

        <!-- konvoy.toml editing support -->
        <completion.contributor
                language="TOML"
                implementationClass="com.konvoy.ide.toml.KonvoyTomlCompletionContributor"/>
        <annotator
                language="TOML"
                implementationClass="com.konvoy.ide.toml.KonvoyTomlAnnotator"/>
        <lang.documentationProvider
                language="TOML"
                implementationClass="com.konvoy.ide.toml.KonvoyTomlDocumentationProvider"/>
        <psi.referenceContributor
                language="TOML"
                implementation="com.konvoy.ide.toml.KonvoyTomlReferenceContributor"/>
        <codeInsight.lineMarkerProvider
                language="TOML"
                implementationClass="com.konvoy.ide.toml.KonvoyTomlLineMarkerProvider"/>

        <!-- Startup activity to detect konvoy.toml on project open -->
        <postStartupActivity
                implementation="com.konvoy.ide.sync.KonvoyStartupActivity"/>

        <!-- Notification group -->
        <notificationGroup id="Konvoy" displayType="BALLOON"/>
    </extensions>

    <projectListeners>
        <listener class="com.konvoy.ide.sync.KonvoyFileListener"
                  topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
    </projectListeners>

    <actions>
        <action id="Konvoy.SyncProject"
                class="com.konvoy.ide.sync.KonvoySyncAction"
                text="Sync Konvoy Project"
                description="Re-sync project model from konvoy.toml"
                icon="AllIcons.Actions.Refresh">
            <add-to-group group-id="BuildMenu" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
