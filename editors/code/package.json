{
  "name": "konvoy-vscode",
  "displayName": "Konvoy",
  "description": "Konvoy build tool integration for VS Code",
  "publisher": "konvoy",
  "version": "1.2.0",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/arncore/konvoy",
    "directory": "editors/code"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:konvoy.toml"
  ],
  "extensionDependencies": [
    "fwcd.kotlin"
  ],
  "extensionPack": [
    "GitLens.detekt"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "konvoy.build",
        "title": "Konvoy: Build",
        "icon": "$(tools)"
      },
      {
        "command": "konvoy.buildRelease",
        "title": "Konvoy: Build (Release)",
        "icon": "$(tools)"
      },
      {
        "command": "konvoy.buildPick",
        "title": "Konvoy: Build...",
        "icon": "$(tools)"
      },
      {
        "command": "konvoy.run",
        "title": "Konvoy: Run",
        "icon": "$(debug-alt)"
      },
      {
        "command": "konvoy.runRelease",
        "title": "Konvoy: Run (Release)",
        "icon": "$(play)"
      },
      {
        "command": "konvoy.toggleRunVariant",
        "title": "Konvoy: Toggle Debug/Release"
      },
      {
        "command": "konvoy.test",
        "title": "Konvoy: Test",
        "icon": "$(beaker)"
      },
      {
        "command": "konvoy.lint",
        "title": "Konvoy: Lint",
        "icon": "$(eye)"
      },
      {
        "command": "konvoy.update",
        "title": "Konvoy: Update",
        "icon": "$(sync)"
      },
      {
        "command": "konvoy.clean",
        "title": "Konvoy: Clean",
        "icon": "$(eraser)"
      },
      {
        "command": "konvoy.cleanAll",
        "title": "Konvoy: Clean All"
      },
      {
        "command": "konvoy.cleanConfirm",
        "title": "Konvoy: Clean (Confirm)",
        "icon": "$(eraser)"
      },
      {
        "command": "konvoy.doctor",
        "title": "Konvoy: Doctor",
        "icon": "$(pulse)"
      },
      {
        "command": "konvoy.toolchainInstall",
        "title": "Konvoy: Install Toolchain"
      },
      {
        "command": "konvoy.toolchainList",
        "title": "Konvoy: List Toolchains"
      }
    ],
    "configuration": {
      "title": "Konvoy",
      "properties": {
        "konvoy.path": {
          "type": "string",
          "default": "",
          "description": "Path to konvoy binary (empty = use PATH)"
        },
        "konvoy.defaultTarget": {
          "type": "string",
          "enum": [
            "",
            "linux_x64",
            "linux_arm64",
            "macos_x64",
            "macos_arm64"
          ],
          "default": "",
          "description": "Default target platform for builds"
        },
        "konvoy.showBuildOutputOnSuccess": {
          "type": "boolean",
          "default": false,
          "description": "Show the output panel even when the build succeeds"
        }
      }
    },
    "languages": [
      {
        "id": "konvoy-toml",
        "filenames": [
          "konvoy.toml"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "konvoy-toml",
        "scopeName": "source.konvoy-toml",
        "path": "./syntaxes/konvoy-toml.tmLanguage.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "konvoy.toml",
        "url": "./schemas/konvoy-toml.schema.json"
      }
    ],
    "problemMatchers": [
      {
        "name": "konvoy-konanc",
        "owner": "konvoy",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": [
          {
            "regexp": "^(.+\\.kt):(\\d+):(\\d+)?:?\\s*(error|warning|info):\\s*(.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5
          }
        ]
      },
      {
        "name": "konvoy-bare",
        "owner": "konvoy",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": [
          {
            "regexp": "^(.+)?:?(\\d+)?:?\\s*(error|warning|info):\\s*(.*)$",
            "file": 1,
            "line": 2,
            "severity": 3,
            "message": 4
          }
        ]
      }
    ],
    "taskDefinitions": [
      {
        "type": "konvoy",
        "properties": {
          "command": {
            "type": "string"
          }
        },
        "required": [
          "command"
        ]
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "konvoy.buildPick",
          "group": "navigation@1",
          "when": "resourceFilename == 'konvoy.toml' || resourceFilename == 'konvoy.lock' || resourceExtname == '.kt'"
        },
        {
          "command": "konvoy.test",
          "group": "navigation@2",
          "when": "resourceFilename == 'konvoy.toml' || resourceFilename == 'konvoy.lock' || resourceExtname == '.kt'"
        },
        {
          "command": "konvoy.update",
          "group": "navigation@3",
          "when": "resourceFilename == 'konvoy.toml' || resourceFilename == 'konvoy.lock' || resourceExtname == '.kt'"
        },
        {
          "command": "konvoy.lint",
          "group": "navigation@4",
          "when": "resourceFilename == 'konvoy.toml' || resourceFilename == 'konvoy.lock' || resourceExtname == '.kt'"
        },
        {
          "command": "konvoy.cleanConfirm",
          "group": "navigation@5",
          "when": "resourceFilename == 'konvoy.toml' || resourceFilename == 'konvoy.lock' || resourceExtname == '.kt'"
        },
        {
          "command": "konvoy.doctor",
          "group": "navigation@6",
          "when": "resourceFilename == 'konvoy.toml' || resourceFilename == 'konvoy.lock' || resourceExtname == '.kt'"
        }
      ],
      "editor/title/run": [
        {
          "command": "konvoy.run",
          "group": "navigation@1",
          "when": "!konvoy.releaseMode && (resourceFilename == 'konvoy.toml' || resourceFilename == 'konvoy.lock' || resourceExtname == '.kt')"
        },
        {
          "command": "konvoy.runRelease",
          "group": "navigation@1",
          "when": "konvoy.releaseMode && (resourceFilename == 'konvoy.toml' || resourceFilename == 'konvoy.lock' || resourceExtname == '.kt')"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild --bundle src/extension.ts --outfile=out/extension.js --external:vscode --platform=node --format=cjs --minify",
    "watch": "esbuild --bundle src/extension.ts --outfile=out/extension.js --external:vscode --platform=node --format=cjs --watch",
    "lint": "eslint src --ext ts",
    "clean": "rm -rf out",
    "compile-tests": "tsc -p tsconfig.json",
    "test": "node ./out/test/runTests.js",
    "pretest": "npm run clean && npm run build && npm run compile-tests",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@types/mocha": "^10.0.0",
    "typescript": "^5.3.0",
    "esbuild": "^0.25.0",
    "@vscode/test-electron": "^2.3.0",
    "mocha": "^10.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3",
    "minimatch": "^10.0.0"
  }
}
