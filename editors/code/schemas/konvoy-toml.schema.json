{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "konvoy.toml",
  "description": "Schema for the Konvoy build tool manifest",
  "type": "object",
  "properties": {
    "package": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "kind": { "type": "string", "enum": ["bin", "lib"] }
      },
      "required": ["name", "version"]
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": true
    },
    "plugins": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
